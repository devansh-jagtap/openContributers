generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  githubId      String?        @unique
  username      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  name          String?
  avatarUrl     String?
  token         String?
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  emailLogs     EmailLog[]
  accounts      Account[]
  sessions      Session[]
}

model Repo {
  id            String         @id @default(cuid())
  owner         String
  name          String
  fullName      String         @unique
  description   String?
  stars         Int            @default(0)
  language      String?
  lastSyncedAt  DateTime?
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  issues        Issue[]

  @@unique([owner, name])
}

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  repoId       String
  active       Boolean  @default(true)
  issuesPerDay Int      @default(1)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo         Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([userId, repoId])
}

model Issue {
  id              String     @id @default(cuid())
  repoId          String
  githubNumber    Int
  title           String
  body            String?
  url             String
  state           String     @default("open")
  labels          String[]
  githubCreatedAt DateTime?
  createdAt       DateTime   @default(now())
  repo            Repo       @relation(fields: [repoId], references: [id], onDelete: Cascade)
  emailLogs       EmailLog[]

  @@unique([repoId, githubNumber])
}

model EmailLog {
  id       String    @id @default(cuid())
  userId   String
  issueId  String
  sentAt   DateTime  @default(now())
  openedAt DateTime?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue    Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
